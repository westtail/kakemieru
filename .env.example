# このファイルをコピーして .env を作成し、各値を設定してください
# cp .env.example .env
#
# 注意: .env は絶対にコミットしないこと（.gitignore に追加済み）

# PostgreSQL 設定
POSTGRES_USER=postgres
# ローカル開発用。本番では fly secrets set POSTGRES_PASSWORD=xxx で強力なパスワードを設定すること
POSTGRES_PASSWORD=password
POSTGRES_DB=kakemieru_development

# Rails 設定
# rails secret で生成: docker compose run --rm web bundle exec rails secret
RAILS_MASTER_KEY=
